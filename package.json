{
  "name": "litedbmodel",
  "version": "2.1.0",
  "description": "A lightweight TypeScript ORM for PostgreSQL, MySQL, and SQLite with Active Record pattern",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./drivers": {
      "types": "./dist/drivers/index.d.ts",
      "default": "./dist/drivers/index.js"
    },
    "./scp": {
      "types": "./dist/scp/index.d.ts",
      "import": "./dist/scp/index.mjs",
      "require": "./dist/scp/index.cjs"
    },
    "./eslint-plugin": {
      "default": "./eslint-plugin/index.js"
    }
  },
  "files": [
    "dist",
    "docs",
    "eslint-plugin"
  ],
  "scripts": {
    "build": "tsc && node scripts/build-scp.mjs",
    "build:scp": "node scripts/build-scp.mjs",
    "watch": "tsc -w",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:integration": "TEST_DB_HOST=localhost vitest run test/integration",
    "parity:capture": "TEST_DB_HOST=localhost TEST_DB_PORT=5433 vitest run test/parity/v1-sql-golden.test.ts",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src",
    "docs": "typedoc",
    "docs:watch": "typedoc --watch",
    "prepublishOnly": "npm run clean && npm run build",
    "docker:up": "docker compose -f docker-compose.test.yml up -d",
    "docker:down": "docker compose -f docker-compose.test.yml down",
    "docker:reset": "docker compose -f docker-compose.test.yml down -v && docker compose -f docker-compose.test.yml up -d",
    "test:integration:docker": "npm run docker:up && sleep 3 && npm run test:integration; npm run docker:down",
    "test:ci": "vitest run test/unit",
    "sync:versions": "node scripts/sync-versions.mjs",
    "sync:versions:check": "node scripts/sync-versions.mjs --check",
    "deps:check": "node scripts/check-no-local-deps.mjs",
    "vendor:bc-php": "node scripts/vendor-behavior-contracts-php.mjs",
    "vendor:bc-php:check": "node scripts/vendor-behavior-contracts-php.mjs --check",
    "conformance:gen": "vitest run --config conformance/vitest.config.ts",
    "conformance:gen:livedb": "vitest run --config conformance/vitest.livedb.config.ts",
    "conformance:vectors": "npm run build:scp && tsx conformance/vectors-runner.ts",
    "conformance:run": "npm run build:scp && tsx conformance/vectors-run.ts",
    "conformance:codegen": "npm run build:scp && tsx conformance/codegen/codegen-runner.ts",
    "conformance:livedb": "tsx conformance/livedb-run.ts",
    "bench:coverage:roundtrip": "npm run build:scp && tsx benchmark/crosslang/coverage-roundtrip.ts",
    "bench:coverage:roundtrip:docker": "npm run docker:livedb:up && sleep 5 && npm run bench:coverage:roundtrip; e=$?; npm run docker:livedb:down; exit $e",
    "docker:livedb:up": "docker compose -f docker-compose.test.yml -f docker-compose.livedb.yml up -d postgres mysql",
    "docker:livedb:down": "docker compose -f docker-compose.test.yml -f docker-compose.livedb.yml down -v",
    "conformance:livedb:docker": "npm run docker:livedb:up && sleep 5 && npm run conformance:gen:livedb && npm run conformance:livedb; e=$?; npm run docker:livedb:down; exit $e"
  },
  "keywords": [
    "orm",
    "postgresql",
    "mysql",
    "sqlite",
    "database",
    "typescript",
    "data-access-layer",
    "active-record",
    "type-safe"
  ],
  "author": "foo-ogawa",
  "license": "MIT",
  "homepage": "https://github.com/foo-ogawa/litedbmodel#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/foo-ogawa/litedbmodel.git"
  },
  "dependencies": {
    "behavior-contracts": "^0.8.0",
    "reflect-metadata": "^0.2.2"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/node": "^20.10.0",
    "@types/pg": "^8.10.9",
    "@vitest/coverage-v8": "^4.1.7",
    "better-sqlite3": "^11.0.0",
    "embedoc": "^0.9.1",
    "esbuild": "^0.28.1",
    "eslint": "^9.39.4",
    "globals": "^17.6.0",
    "mysql2": "^3.16.0",
    "pg": "^8.11.3",
    "terser": "^5.44.1",
    "tsx": "^4.22.3",
    "typedoc": "^0.28.15",
    "typedoc-plugin-markdown": "^4.9.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.60.0",
    "vitest": "^4.1.7"
  },
  "peerDependencies": {
    "better-sqlite3": "^9.0.0 || ^10.0.0 || ^11.0.0",
    "mysql2": "^3.0.0",
    "pg": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "pg": {
      "optional": true
    },
    "better-sqlite3": {
      "optional": true
    },
    "mysql2": {
      "optional": true
    }
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "js-yaml": "^4.2.0"
  }
}
