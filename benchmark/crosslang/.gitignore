# Transient run output
.crosslang-results.json
# Per-language standalone-bench CSVs (each bench writes .results/<lang>.csv; the collector reads
# them → CROSS-LANG.md). Raw per-run output, regenerated every run — NEVER commit.
.results/
# Compiled rust adapter (the lm_orm ORM-plan executor) build dir
adapters/rust/target/
# Compiled TS adapter — the bench runner is esbuild-bundled to plain JS at run time (run.ts's build
# step) and launched with bare `node` so esbuild/tsx is NOT resident in the MEASURED process. Like the
# rust/go native binaries above, this is regenerated every run — NEVER commit.
adapters/ts/orm-runner.built.mjs
# Python bytecode
adapters/python/__pycache__/
**/__pycache__/

# Generated build output — regenerated at run time (NEVER commit). Ignore everything under
# generated/ EXCEPT the committed, drift-checked #63 orm-plan.json artifact (the language-neutral
# SSoT every runtime consumes).
generated/*
!generated/orm-plan.json
